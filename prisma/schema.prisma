generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ModuleType {
  cpu
  page
  disk
  deadlock
}

model UserProfile {
  clerkUserId String   @id
  email       String?
  name        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SimulationProject {
  id          String     @id @default(cuid())
  clerkUserId String
  title       String
  moduleType  ModuleType
  algorithm   String
  inputData   Json
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([clerkUserId, moduleType])
}

model SimulationRun {
  id          String     @id @default(cuid())
  clerkUserId String
  moduleType  ModuleType
  algorithm   String
  inputData   Json
  resultData  Json
  createdAt   DateTime   @default(now())

  @@index([clerkUserId, createdAt])
}

model SavedPreset {
  id          String     @id @default(cuid())
  clerkUserId String
  name        String
  moduleType  ModuleType
  algorithm   String
  presetData  Json
  isPublic    Boolean    @default(false)
  createdAt   DateTime   @default(now())

  @@index([clerkUserId, moduleType])
}

model RecentActivity {
  id          String   @id @default(cuid())
  clerkUserId String
  action      String
  metadata    Json
  createdAt   DateTime @default(now())

  @@index([clerkUserId, createdAt])
}
